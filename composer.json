{
    "name": "macpaw/behat-orm-context",
    "description": "Behat Context for testing Symfony ORM",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "MacPaw",
        "symfony",
        "behat",
        "BDD",
        "Context",
        "ORM"
    ],
    "authors": [
        {
            "name": "Vladislav Hanziuk",
            "email": "ganzyukv@macpaw.com",
            "homepage": "https://macpaw.com/",
            "role": "Software Engineer"
        },
        {
            "name": "Serhii Donii",
            "email": "serhii.donii@macpaw.com",
            "homepage": "https://macpaw.com/",
            "role": "Software Engineer"
        },
        {
            "name": "Yozhef Hisem",
            "email": "hisemjo@gmail.com",
            "homepage": "https://macpaw.com/",
            "role": "Software Engineer"
        }
    ],
    "require": {
        "ext-json": "*",
        "php": "^8.1",
        "behat/behat": "^3.0",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.4 || ^7.0 || ^8.0",
        "macpaw/similar-arrays": "^1.0",
        "doctrine/orm": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "rector/rector": "^1.0 || ^2.0",
        "slevomat/coding-standard": "^8.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan-doctrine": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "BehatOrmContext\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BehatOrmContext\\Tests\\": "tests"
        }
    },
    "scripts": {
        "composer-validate": "composer validate",
        "phpstan": "./vendor/bin/phpstan analyse -l max",
        "code-style": "./vendor/bin/phpcs",
        "code-style-fix": "./vendor/bin/phpcbf",
        "phpunit": "./vendor/bin/phpunit --do-not-fail-on-phpunit-warning --do-not-fail-on-phpunit-deprecation",
        "phpunit-html-coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-html=coverage",
        "rector": "./vendor/bin/rector process --dry-run",
        "rector-fix": "./vendor/bin/rector process",
        "dev-checks": [
            "composer validate",
            "@phpstan",
            "@code-style",
            "@phpunit"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.1.0"
        }
    }
}
